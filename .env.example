# =====================================================================
# .env — copy to .env on EACH relay VM and fill in per that node's identity.
# GUN_CHAT_PEERS / GUN_SIGNAL_PEERS must list the OTHER nodes, never itself.
# =====================================================================

# ── Identity — set differently per VM: chat-1/2/3, signal-1/2/3 ──
NODE_ID=chat-1

# ── Ports ──
CHAT_PORT=8765
SIGNAL_PORT=8766

# ── Notification service (already deployed) ──
# Every server that sends a notification (chat-server.js, signaling-server.js
# once you wire call notifications through it) needs this.
NOTIFICATION_SERVICE_URL=http:127.0.0.1:3007

# ── Chat relay mesh ──
# On chat-1's .env:
GUN_CHAT_PEERS=wss://chat-2.trustgrid.com/gun,wss://chat-3.trustgrid.com/gun
# On chat-2's .env:
#   GUN_CHAT_PEERS=wss://chat-1.trustgrid.com/gun,wss://chat-3.trustgrid.com/gun
# On chat-3's .env:
#   GUN_CHAT_PEERS=wss://chat-1.trustgrid.com/gun,wss://chat-2.trustgrid.com/gun

GUN_TIMEOUT=9000
DEFAULT_GROUP_ID=first_responder_group

# ── Signaling relay mesh ──
# On signal-1's .env:
GUN_SIGNAL_PEERS=wss://signal-2.trustgrid.com/gun,wss://signal-3.trustgrid.com/gun
# On signal-2's .env:
#   GUN_SIGNAL_PEERS=wss://signal-1.trustgrid.com/gun,wss://signal-3.trustgrid.com/gun
# On signal-3's .env:
#   GUN_SIGNAL_PEERS=wss://signal-1.trustgrid.com/gun,wss://signal-2.trustgrid.com/gun

SIGNAL_TTL_MS=90000
SWEEP_INTERVAL_MS=30000
MEMORY_RESTART_THRESHOLD_MB=512
